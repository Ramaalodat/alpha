# Application Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1
API_PREFIX=/api

# Database Configuration
DATABASE_URL="postgresql://neondb_owner:npg_LGZqKYcwQ8U1@ep-lively-bird-aborkpez-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key-change-in-production-minimum-64-chars-abcdefghijklmnop
JWT_REFRESH_SECRET=your-different-super-secret-jwt-refresh-key-change-in-production-minimum-64-chars-xyz
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMS Service Configuration (Mock for development)
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OTP Configuration
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_WINDOW=15
OTP_DAILY_LIMIT=10

# Encryption Configuration
ENCRYPTION_KEY=12345678901234567890123456789012
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESS_REQUESTS=false

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf
UPLOAD_DESTINATION=uploads/

# External API Configuration
AI_SERVICE_URL=https://api.openai.com/v1
AI_SERVICE_API_KEY=
AI_MODEL=gpt-3.5-turbo

# Security Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
HELMET_ENABLED=true

# Background Jobs Configuration
BULL_REDIS_URL=redis://localhost:6379/1
QUEUE_CONCURRENCY=5

# Monitoring Configuration
SENTRY_DSN=
ANALYTICS_ENABLED=false

