# Application Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1
API_PREFIX=/api/v1

# Database Configuration
DATABASE_URL=postgresql://neondb_owner:npg_LGZqKYcwQ8U1@ep-lively-bird-aborkpez-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMS Service Configuration (Twilio)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# OTP Configuration
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_WINDOW=15
OTP_DAILY_LIMIT=10

# Encryption Configuration
ENCRYPTION_KEY=your-32-byte-encryption-key-for-sensitive-data-encryption
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESS_REQUESTS=false

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf
UPLOAD_DESTINATION=uploads/

# External API Configuration
AI_SERVICE_URL=https://api.openai.com/v1
AI_SERVICE_API_KEY=your-openai-api-key
AI_MODEL=gpt-3.5-turbo

# Notification Configuration
PUSH_NOTIFICATION_SERVICE=fcm
FCM_SERVER_KEY=your-fcm-server-key

# Security Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true
HELMET_ENABLED=true

# Background Jobs Configuration
BULL_REDIS_URL=redis://localhost:6379/1
QUEUE_CONCURRENCY=5

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health

# Monitoring and Analytics
SENTRY_DSN=your-sentry-dsn-for-error-tracking
ANALYTICS_ENABLED=true

# Development Configuration
DEV_SEED_DATABASE=true
DEV_AUTO_MIGRATE=true
DEV_LOG_QUERIES=false

# Production Configuration (Override in production)
# DATABASE_URL=your-production-database-url
# REDIS_URL=your-production-redis-url
# JWT_ACCESS_SECRET=your-production-jwt-access-secret
# JWT_REFRESH_SECRET=your-production-jwt-refresh-secret
# ENCRYPTION_KEY=your-production-encryption-key