// =============================================
// BASIRA Database Schema
// Production-ready PostgreSQL database with Prisma
// Designed for financial guidance application targeting Jordanian youth
// =============================================

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// ENUMS - Define all enumeration types
// =============================================

enum UserStatus {
  PENDING_VERIFICATION
  VERIFIED
  SUSPENDED
  DELETED

  @@map("user_status")
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
  DELETED

  @@map("goal_status")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  ADJUSTMENT

  @@map("transaction_type")
}

enum OtpPurpose {
  REGISTRATION
  LOGIN
  PASSWORD_RESET
  PHONE_VERIFICATION
  ACCOUNT_RECOVERY

  @@map("otp_purpose")
}

enum InsightType {
  SPENDING_PATTERN
  GOAL_RECOMMENDATION
  BUDGET_ALERT
  SAVING_TIP
  FINANCIAL_HEALTH
  BEHAVIORAL_ANALYSIS

  @@map("insight_type")
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  URGENT

  @@map("priority_level")
}

enum NotificationType {
  GOAL_MILESTONE
  SPENDING_ALERT
  WEEKLY_SUMMARY
  MONTHLY_SUMMARY
  EDUCATIONAL
  SYSTEM
  PROMOTIONAL

  @@map("notification_type")
}

enum ExpenseFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME

  @@map("expense_frequency")
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_PAYMENT
  OTHER

  @@map("payment_method")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  VERIFY
  RESET_PASSWORD
  CHANGE_STATUS

  @@map("audit_action")
}

// =============================================
// CORE USER MANAGEMENT
// =============================================

// Users table - Core user information
model User {
  id          String     @id @default(uuid()) @db.Uuid
  phoneNumber String     @unique @map("phone_number") @db.VarChar(15)
  fullName    String     @map("full_name") @db.VarChar(255)
  birthDate   DateTime   @map("birth_date") @db.Date
  
  // Authentication fields
  passwordHash String    @map("password_hash") @db.VarChar(255)
  status       UserStatus @default(PENDING_VERIFICATION)
  isOnboarded  Boolean    @default(false) @map("is_onboarded")
  
  // Tracking fields
  lastLoginAt DateTime?  @map("last_login_at")
  emailVerifiedAt DateTime? @map("email_verified_at")
  phoneVerifiedAt DateTime? @map("phone_verified_at")
  
  // Soft delete
  deletedAt   DateTime? @map("deleted_at")
  
  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relationships
  profiles         UserProfile[]
  goals            FinancialGoal[]
  expenses         Expense[]
  income           Income[]
  goalTransactions GoalTransaction[]
  sessions         UserSession[]
  otpCodes         OtpCode[]
  insights         AiInsight[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  settings         UserSettings?
  customCategories ExpenseCategory[]
  budgets          Budget[]
  achievements     UserAchievement[]
  
  // Self-referencing relationships for profile versions
  createdProfiles  UserProfile[] @relation("ProfileCreator")

  @@index([phoneNumber])
  @@index([status])
  @@index([isOnboarded])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("users")
}

// User profiles with full versioning and audit trail
model UserProfile {
  id                      String  @id @default(uuid()) @db.Uuid
  userId                  String  @map("user_id") @db.Uuid
  
  // Financial information
  monthlyIncome          Decimal @map("monthly_income") @db.Decimal(12, 2)
  basicExpenses          Decimal @map("basic_expenses") @db.Decimal(12, 2)
  financialGoal          String? @map("financial_goal") @db.Text
  primarySpendingCategory String @map("primary_spending_category") @db.VarChar(100)
  
  // Additional profile data
  occupation             String? @db.VarChar(100)
  educationLevel         String? @map("education_level") @db.VarChar(50)
  familySize            Int?     @map("family_size") @default(1)
  hasEmergencyFund      Boolean  @map("has_emergency_fund") @default(false)
  riskTolerance         String?  @map("risk_tolerance") @db.VarChar(20)
  
  // Version control
  version               Int     @default(1)
  isCurrent             Boolean @default(true) @map("is_current")
  changeReason          String? @map("change_reason") @db.Text
  
  // Audit fields
  createdAt             DateTime @default(now()) @map("created_at")
  createdBy             String? @map("created_by") @db.Uuid

  // Relationships
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator User? @relation("ProfileCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, isCurrent])
  @@index([version])
  @@index([createdAt])
  @@map("user_profiles")
}

// Income tracking (Monthly Income entity)
model Income {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  
  // Income details
  amount      Decimal  @db.Decimal(12, 2)
  source      String   @db.VarChar(255)
  description String?  @db.Text
  frequency   ExpenseFrequency @default(MONTHLY)
  
  // Date tracking
  incomeDate  DateTime @map("income_date") @db.Date
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  
  // Status
  isActive    Boolean  @default(true) @map("is_active")
  isRecurring Boolean  @default(false) @map("is_recurring")
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([incomeDate])
  @@index([isActive])
  @@index([deletedAt])
  @@map("income")
}

// User settings and preferences
model UserSettings {
  id                   String  @id @default(uuid()) @db.Uuid
  userId               String  @unique @map("user_id") @db.Uuid
  
  // Notification preferences
  notificationsEnabled Boolean @default(true) @map("notifications_enabled")
  emailNotifications   Boolean @default(false) @map("email_notifications")
  pushNotifications    Boolean @default(true) @map("push_notifications")
  smsNotifications     Boolean @default(true) @map("sms_notifications")
  weeklySummary        Boolean @default(true) @map("weekly_summary")
  monthlySummary       Boolean @default(true) @map("monthly_summary")
  spendingAlerts       Boolean @default(true) @map("spending_alerts")
  goalReminders        Boolean @default(true) @map("goal_reminders")
  
  // App preferences
  language             String  @default("ar") @db.VarChar(5)
  currency             String  @default("JOD") @db.VarChar(3)
  timezone             String  @default("Asia/Amman") @db.VarChar(50)
  theme                String  @default("light") @db.VarChar(20)
  dateFormat           String  @default("DD/MM/YYYY") @map("date_format") @db.VarChar(20)
  
  // Privacy settings
  dataSharing          Boolean @default(false) @map("data_sharing")
  analyticsOptIn       Boolean @default(true) @map("analytics_opt_in")
  marketingOptIn       Boolean @default(false) @map("marketing_opt_in")
  
  // Security settings
  twoFactorEnabled     Boolean @default(false) @map("two_factor_enabled")
  sessionTimeout       Int     @default(30) @map("session_timeout")
  
  // Budget preferences
  defaultBudgetPeriod  String  @default("MONTHLY") @map("default_budget_period") @db.VarChar(20)
  budgetAlertThreshold Int     @default(80) @map("budget_alert_threshold")
  
  // Timestamps
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// =============================================
// AUTHENTICATION & SECURITY
// =============================================

// OTP codes for verification
model OtpCode {
  id          String     @id @default(uuid()) @db.Uuid
  phoneNumber String     @map("phone_number") @db.VarChar(15)
  code        String     @db.VarChar(6)
  purpose     OtpPurpose
  
  // Usage tracking
  isUsed      Boolean    @default(false) @map("is_used")
  attempts    Int        @default(0)
  usedAt      DateTime?  @map("used_at")
  
  // Security
  ipAddress   String?    @map("ip_address") @db.VarChar(45)
  userAgent   String?    @map("user_agent") @db.Text
  
  // Expiration
  expiresAt   DateTime   @map("expires_at")
  
  // Timestamps
  createdAt   DateTime   @default(now()) @map("created_at")
  
  // Relationships
  userId      String?    @map("user_id") @db.Uuid
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phoneNumber])
  @@index([code, purpose, isUsed])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("otp_codes")
}

// User sessions for JWT refresh tokens
model UserSession {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  refreshTokenHash String   @map("refresh_token_hash") @db.VarChar(255)
  
  // Device information
  deviceInfo       Json?    @map("device_info")
  deviceId         String?  @map("device_id") @db.VarChar(255)
  ipAddress        String?  @map("ip_address") @db.VarChar(45)
  userAgent        String?  @map("user_agent") @db.Text
  
  // Session status
  isActive         Boolean  @default(true) @map("is_active")
  isRevoked        Boolean  @default(false) @map("is_revoked")
  revokedAt        DateTime? @map("revoked_at")
  revokeReason     String?  @map("revoke_reason") @db.Text
  
  // Tracking
  expiresAt        DateTime @map("expires_at")
  lastUsedAt       DateTime @default(now()) @map("last_used_at")
  
  // Timestamps
  createdAt        DateTime @default(now()) @map("created_at")

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
  @@index([isActive])
  @@index([expiresAt])
  @@index([deviceId])
  @@map("user_sessions")
}

// =============================================
// FINANCIAL GOALS & TRANSACTIONS
// =============================================

// Financial goals
model FinancialGoal {
  id                 String     @id @default(uuid()) @db.Uuid
  userId             String     @map("user_id") @db.Uuid
  
  // Goal details
  icon               String     @db.VarChar(100)
  name               String     @db.VarChar(255)
  description        String?    @db.Text
  targetAmount       Decimal    @map("target_amount") @db.Decimal(12, 2)
  currentAmount      Decimal    @default(0) @map("current_amount") @db.Decimal(12, 2)
  targetDate         DateTime   @map("target_date") @db.Date
  
  // Status
  status             GoalStatus @default(ACTIVE)
  priority           PriorityLevel @default(MEDIUM)
  
  // Progress tracking
  progressPercentage Decimal?   @map("progress_percentage") @db.Decimal(5, 2)
  completedAt        DateTime?  @map("completed_at")
  
  // Milestones tracking
  milestone25        Boolean    @default(false) @map("milestone_25")
  milestone50        Boolean    @default(false) @map("milestone_50")
  milestone75        Boolean    @default(false) @map("milestone_75")
  milestone100       Boolean    @default(false) @map("milestone_100")
  
  // Category
  category           String?    @db.VarChar(50)
  tags               String[]
  
  // Notes
  notes              String?    @db.Text
  
  // Soft delete
  deletedAt          DateTime?  @map("deleted_at")
  
  // Timestamps
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  // Relationships
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions GoalTransaction[]

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@index([targetDate])
  @@index([deletedAt])
  @@map("financial_goals")
}

// Goal transactions (money allocated to goals)
model GoalTransaction {
  id              String          @id @default(uuid()) @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  goalId          String          @map("goal_id") @db.Uuid
  
  // Transaction details
  amount          Decimal         @db.Decimal(10, 2)
  transactionType TransactionType @map("transaction_type")
  description     String?         @db.Text
  
  // Balance tracking
  balanceBefore   Decimal         @map("balance_before") @db.Decimal(12, 2)
  balanceAfter    Decimal         @map("balance_after") @db.Decimal(12, 2)
  
  // Date
  transactionDate DateTime        @map("transaction_date") @db.Date
  
  // Metadata
  metadata        Json?
  
  // Timestamps
  createdAt       DateTime        @default(now()) @map("created_at")

  // Relationships
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal FinancialGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([goalId])
  @@index([transactionDate])
  @@index([createdAt])
  @@map("goal_transactions")
}

// =============================================
// EXPENSE TRACKING
// =============================================

// Expense categories (Essential Expenses & Spending Categories)
model ExpenseCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  nameAr    String?  @map("name_ar") @db.VarChar(100)
  icon      String?  @db.VarChar(100)
  color     String   @default("#6B7280") @db.VarChar(7)
  
  // Category type
  isDefault Boolean  @default(false) @map("is_default")
  isEssential Boolean @default(false) @map("is_essential")
  
  // Order and grouping
  displayOrder Int?   @map("display_order")
  parentId    String? @map("parent_id") @db.Uuid
  
  // Ownership
  createdBy String?  @map("created_by") @db.Uuid
  
  // Status
  isActive  Boolean  @default(true) @map("is_active")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  creator  User?     @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  expenses Expense[]
  budgets  Budget[]

  @@index([isDefault])
  @@index([isEssential])
  @@index([createdBy])
  @@index([parentId])
  @@map("expense_categories")
}

// Expenses tracking (Spending Records)
model Expense {
  id                 String         @id @default(uuid()) @db.Uuid
  userId             String         @map("user_id") @db.Uuid
  categoryId         String         @map("category_id") @db.Uuid
  
  // Expense details
  amount             Decimal        @db.Decimal(10, 2)
  description        String?        @db.Text
  paymentMethod      PaymentMethod? @map("payment_method")
  
  // Location and merchant
  location           String?        @db.VarChar(255)
  merchantName       String?        @map("merchant_name") @db.VarChar(255)
  
  // Attachments
  receiptUrl         String?        @map("receipt_url") @db.VarChar(500)
  receiptData        Json?          @map("receipt_data")
  
  // Recurring expenses
  isRecurring        Boolean        @default(false) @map("is_recurring")
  recurringFrequency ExpenseFrequency? @map("recurring_frequency")
  recurringEndDate   DateTime?      @map("recurring_end_date") @db.Date
  parentExpenseId    String?        @map("parent_expense_id") @db.Uuid
  
  // Date
  expenseDate        DateTime       @default(now()) @map("expense_date") @db.Date
  
  // Tags and notes
  tags               String[]
  notes              String?        @db.Text
  
  // AI Processing
  isAiProcessed      Boolean        @default(false) @map("is_ai_processed")
  aiCategory         String?        @map("ai_category") @db.VarChar(100)
  aiConfidence       Decimal?       @map("ai_confidence") @db.Decimal(3, 2)
  
  // Soft delete
  deletedAt          DateTime?      @map("deleted_at")
  
  // Timestamps
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  // Relationships
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@index([userId, expenseDate])
  @@index([expenseDate])
  @@index([isRecurring])
  @@index([deletedAt])
  @@map("expenses")
}

// Budget tracking
model Budget {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  categoryId  String?  @map("category_id") @db.Uuid
  
  // Budget details
  name        String   @db.VarChar(255)
  amount      Decimal  @db.Decimal(12, 2)
  period      String   @db.VarChar(20)
  
  // Date range
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  
  // Tracking
  spent       Decimal  @default(0) @db.Decimal(12, 2)
  remaining   Decimal  @default(0) @db.Decimal(12, 2)
  
  // Alerts
  alertAt     Int      @map("alert_at") @default(80)
  alerted     Boolean  @default(false)
  
  // Status
  isActive    Boolean  @default(true) @map("is_active")
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relationships
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ExpenseCategory? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@index([startDate, endDate])
  @@index([isActive])
  @@map("budgets")
}

// =============================================
// AI INSIGHTS & ANALYTICS
// =============================================

// AI insights and recommendations
model AiInsight {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  
  // Insight details
  insightType InsightType   @map("insight_type")
  title       String        @db.VarChar(255)
  titleAr     String?       @map("title_ar") @db.VarChar(255)
  description String        @db.Text
  descriptionAr String?     @map("description_ar") @db.Text
  
  // Priority
  priority    PriorityLevel @default(MEDIUM)
  score       Decimal?      @db.Decimal(3, 2)
  
  // Status
  isRead      Boolean       @default(false) @map("is_read")
  isDismissed Boolean       @default(false) @map("is_dismissed")
  isActedOn   Boolean       @default(false) @map("is_acted_on")
  
  // Data
  data        Json?
  actionUrl   String?       @map("action_url") @db.VarChar(500)
  
  // Expiration
  expiresAt   DateTime?     @map("expires_at")
  readAt      DateTime?     @map("read_at")
  dismissedAt DateTime?     @map("dismissed_at")
  
  // Timestamps
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([insightType])
  @@index([priority])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("ai_insights")
}

// =============================================
// NOTIFICATIONS
// =============================================

// Notifications system
model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  
  // Notification details
  type        NotificationType
  title       String           @db.VarChar(255)
  titleAr     String?          @map("title_ar") @db.VarChar(255)
  message     String           @db.Text
  messageAr   String?          @map("message_ar") @db.Text
  
  // Status
  isRead      Boolean          @default(false) @map("is_read")
  isSent      Boolean          @default(false) @map("is_sent")
  
  // Delivery
  channels    String[]
  priority    PriorityLevel    @default(MEDIUM)
  
  // Timing
  scheduledAt DateTime?        @map("scheduled_at")
  sentAt      DateTime?        @map("sent_at")
  readAt      DateTime?        @map("read_at")
  
  // Related data
  data        Json?
  actionUrl   String?          @map("action_url") @db.VarChar(500)
  imageUrl    String?          @map("image_url") @db.VarChar(500)
  
  // Tracking
  deliveryStatus String?       @map("delivery_status") @db.VarChar(50)
  errorMessage   String?       @map("error_message") @db.Text
  
  // Timestamps
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([type])
  @@index([isSent])
  @@index([scheduledAt])
  @@index([createdAt])
  @@map("notifications")
}

// =============================================
// GAMIFICATION & ACHIEVEMENTS
// =============================================

// User achievements
model UserAchievement {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  
  // Achievement details
  achievementKey String  @map("achievement_key") @db.VarChar(100)
  title         String   @db.VarChar(255)
  titleAr       String?  @map("title_ar") @db.VarChar(255)
  description   String   @db.Text
  descriptionAr String?  @map("description_ar") @db.Text
  icon          String   @db.VarChar(100)
  
  // Progress
  progress      Int      @default(0)
  target        Int
  isCompleted   Boolean  @default(false) @map("is_completed")
  completedAt   DateTime? @map("completed_at")
  
  // Rewards
  pointsEarned  Int      @default(0) @map("points_earned")
  
  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementKey])
  @@index([userId])
  @@index([isCompleted])
  @@map("user_achievements")
}

// =============================================
// AUDIT LOGGING
// =============================================

// Comprehensive audit log for all user actions
model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  
  // Action details
  action     AuditAction
  entityType String      @map("entity_type") @db.VarChar(50)
  entityId   String?     @map("entity_id") @db.Uuid
  
  // Changes tracking
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  changes    Json?
  
  // Request context
  ipAddress  String?     @map("ip_address") @db.VarChar(45)
  userAgent  String?     @map("user_agent") @db.Text
  requestId  String?     @map("request_id") @db.Uuid
  endpoint   String?     @db.VarChar(255)
  method     String?     @db.VarChar(10)
  
  // Additional metadata
  metadata   Json?
  success    Boolean     @default(true)
  errorMessage String?   @map("error_message") @db.Text
  
  // Timestamps
  createdAt  DateTime    @default(now()) @map("created_at")

  // Relationships
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([requestId])
  @@map("audit_log")
}
